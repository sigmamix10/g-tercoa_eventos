# Servidor
PORT=5000
JWT_SECRET=g_tercoa_secret_key_12345

# Configurações de E-mail (SMTP)
# Preencha estes campos em produção para ativar o envio de e-mails reais.
# Se deixados vazios, o sistema usará o modo de simulação (fallback) salvando os e-mails na pasta backend/sent_emails/
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="G-TERCOA Eventos <no-reply@gtercoa.org>"
